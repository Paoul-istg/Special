<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Monthsary ❤️</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&family=Great+Vibes&display=swap" rel="stylesheet">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
}

body{
background:linear-gradient(135deg,#ff9ec4,#ffd6e8,#ffeef6);
overflow-x:hidden;
color:#fff;
text-align:center;
}

.hero{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
flex-direction:column;
padding:20px;
}

h1{
font-family:"Great Vibes",cursive;
font-size:70px;
text-shadow:2px 2px 10px rgba(0,0,0,.2);
}

.hero p{
font-size:20px;
margin-top:15px;
}

button{
padding:15px 35px;
border:none;
border-radius:40px;
margin-top:30px;
background:white;
color:#ff4d88;
font-size:18px;
font-weight:bold;
cursor:pointer;
transition:.3s;
box-shadow:0 10px 20px rgba(0,0,0,.2);
}

button:hover{
transform:scale(1.1);
}

section{
padding:70px 20px;
}

.card{
background:rgba(255,255,255,.18);
backdrop-filter:blur(10px);
padding:30px;
border-radius:20px;
max-width:800px;
margin:auto;
box-shadow:0 10px 30px rgba(0,0,0,.2);
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-top:30px;
}

.gallery img{
width:100%;
height:280px;
object-fit:cover;
border-radius:20px;
transition:.4s;
}

.gallery img:hover{
transform:scale(1.05);
}

ul{
list-style:none;
font-size:20px;
line-height:2;
}

.hidden{
display:none;
animation:fade 1s;
}

@keyframes fade{
from{opacity:0;}
to{opacity:1;}
}

.counter{
font-size:28px;
margin-top:20px;
font-weight:bold;
}

.heart{
position:fixed;
bottom:-20px;
font-size:20px;
animation:float 8s linear infinite;
color:white;
pointer-events:none;
}

@keyframes float{
0%{
transform:translateY(0) rotate(0);
opacity:1;
}
100%{
transform:translateY(-120vh) rotate(360deg);
opacity:0;
}
}

footer{
padding:50px;
font-size:18px;
}

#surprise{
font-size:30px;
margin-top:30px;
display:none;
animation:fade 1s;
}
</style>

</head>
<body>

<div class="hero">

<h1>Happy Monthsary ❤️</h1>

<p>Every month with you is another chapter of my favorite love story.</p>

<button onclick="scrollToLetter()">Open My Heart 💌</button>

</div>

<section>

<div class="card">

<h2>💌 My Letter</h2>

<p style="margin-top:20px;line-height:2;font-size:18px;">

My Love,

<br><br>

Happy Monthsary, my beautiful girl. ❤️

Thank you for being my happiness, my peace, and the person who makes every ordinary day feel special.

No matter what happens, I promise to keep choosing you, loving you, supporting you, and making memories with you.

Every laugh, every conversation, every little moment with you becomes something I treasure.

You are my favorite notification, my comfort person, and my greatest blessing.

I can't wait for all the months and years we'll celebrate together.

I love you more than words can ever explain.

Forever yours. ❤️

</p>

</div>

</section>

<section>

<div class="card">

<h2>⏳ We've Been Together For</h2>

<div class="counter" id="counter"></div>

</div>

</section>

<section>

<div class="card">

<h2>📸 Our Memories</h2>

<div class="gallery">

<img src="photo1.jpg">
<img src="photo2.jpg">
<img src="photo3.jpg">
<img src="photo4.jpg">
<img src="photo5.jpg">
<img src="photo6.jpg">

</div>

</div>

</section>

<section>

<div class="card">

<h2>🌸 Reasons Why I Love You</h2>

<ul>

<li>❤️ Your beautiful smile</li>
<li>❤️ Your caring heart</li>
<li>❤️ You always make me laugh</li>
<li>❤️ You're my safe place</li>
<li>❤️ You make life brighter</li>
<li>❤️ Simply because you're YOU</li>

</ul>

</div>

</section>

<section>

<div class="card">

<h2>✨ One More Thing...</h2>

<button onclick="showLove()">

Click Me 💖

</button>

<div id="surprise">

🥹❤️

<h2>I LOVE YOU MORE THAN YESTERDAY, BUT LESS THAN TOMORROW.</h2>

<p style="margin-top:20px;">
Happy Monthsary, My Love 💕
</p>

</div>

</div>

</section>

<footer>

Made with infinite love ❤️

</footer>

<!-- Optional Music -->
<!--
<audio autoplay loop>
<source src="music.mp3" type="audio/mpeg">
</audio>
-->

<script>

function scrollToLetter(){
window.scrollTo({
top:window.innerHeight,
behavior:"smooth"
});
}

function showLove(){
document.getElementById("surprise").style.display="block";
}

const startDate=new Date("2025-07-27");

function updateCounter(){

const now=new Date();

const diff=now-startDate;

const days=Math.floor(diff/(1000*60*60*24));

document.getElementById("counter").innerHTML=
days+" Days Together ❤️";

}

updateCounter();

setInterval(updateCounter,1000);

function createHeart(){

const heart=document.createElement("div");

heart.className="heart";

heart.innerHTML="❤";

heart.style.left=Math.random()*100+"vw";

heart.style.fontSize=Math.random()*20+15+"px";

heart.style.animationDuration=Math.random()*4+5+"s";

document.body.appendChild(heart);

setTimeout(()=>{
heart.remove();
},9000);

}

setInterval(createHeart,300);

</script>

</body>
</html>
